return {
    is_master = false,

    node_name = nil,

    log_level = "INFO",
    log_to_master = true,
    log_max_files = 5,
    log_max_size = 16384,

    -- OS updates require explicit confirmation by default.
    -- Set to true to let os-updater apply new versions without asking.
    auto_update = false,

    network = {
        protocol = "unison/1",
        heartbeat_interval = 5,
        ack_timeout = 2,
        ack_retries = 3,
    },

    -- Bus ACL (optional): whitelist who can send a given RPC type
    -- to this device. Keys are message types; values can be:
    --   true/false
    --   { "1", "7" }                       -- allowlist
    --   { allow = { "1" }, deny = { "9" } } -- deny wins
    --   "*"                                -- allow anyone
    -- Example:
    -- rpc_acl = {
    --     exec = { "1" },          -- only device #1 can rexec here
    --     mine_order = { "1", "2" },
    --     mine_cancel = { "1", "2" },
    -- },
    rpc_acl = {},

    master = {
        secret = "CHANGE_ME_BEFORE_FIRST_BOOT",
        nonce_window = 60,
        nonce_cache = 1000,
    },

    displays = {
        mirror_all = true,
        monitors = {},
    },

    create_bridge = {
        stress_in = nil,
        storage_inventories = {},
        redstone_outputs = {},
    },

    -- Dispatcher: set on exactly ONE node in the fleet (typically the
    -- master PC). The dispatcher service then matches queued mining
    -- selections to idle worker turtles. Other nodes leave this nil.
    dispatcher = false,

    -- Workers (turtles) point at the dispatcher's device id so they
    -- know who to send worker_register / worker_idle / mine_done to.
    -- The surveyor pocket app uses the same id to ship selection_queue.
    -- dispatcher_id = "12",

    -- Free-form role tag the dispatcher matches against when assigning
    -- jobs. Common values: "mining", "farming", "lumber". A turtle
    -- with no kind is treated as "any".
    -- kind = "mining",

    -- Cross-world isolation. If you connect computers from multiple
    -- Minecraft worlds / save files to the SAME bus server, set a
    -- distinct world_id per world so they can't see each other on
    -- /api/devices, /api/messages and /api/broadcast. Devices that
    -- omit this default to "default" — fine for single-world setups.
    -- world_id = "alpha",
}
