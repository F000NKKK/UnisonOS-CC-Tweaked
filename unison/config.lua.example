return {
    is_master = false,

    node_name = nil,

    log_level = "INFO",
    log_to_master = true,
    log_max_files = 5,
    log_max_size = 16384,

    -- OS updates require explicit confirmation by default.
    -- Set to true to let os-updater apply new versions without asking.
    auto_update = false,

    network = {
        protocol = "unison/1",
        heartbeat_interval = 5,
        ack_timeout = 2,
        ack_retries = 3,
    },

    -- Bus ACL (optional): whitelist who can send a given RPC type
    -- to this device. Keys are message types; values can be:
    --   true/false
    --   { "1", "7" }                       -- allowlist
    --   { allow = { "1" }, deny = { "9" } } -- deny wins
    --   "*"                                -- allow anyone
    -- Example:
    -- rpc_acl = {
    --     exec = { "1" },          -- only device #1 can rexec here
    --     mine_order = { "1", "2" },
    --     mine_cancel = { "1", "2" },
    -- },
    rpc_acl = {},

    master = {
        secret = "CHANGE_ME_BEFORE_FIRST_BOOT",
        nonce_window = 60,
        nonce_cache = 1000,
    },

    displays = {
        mirror_all = true,
        monitors = {},
    },

    create_bridge = {
        stress_in = nil,
        storage_inventories = {},
        redstone_outputs = {},
    },
}
